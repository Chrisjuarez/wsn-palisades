# OpenTopography API key for fetching DEMs
# Sign up at https://opentopography.org/ and request a key
OPENTOPO_API_KEY=

# NREL NSRDB credentials for solar irradiance data
# Sign up at https://developer.nrel.gov/signup/
NSRDB_API_KEY=
NSRDB_EMAIL=

# S3 bucket name for fetching the large DEM/DSM/CHM rasters
# (the bucket is configured public-read in this project)
WSN_DATA_BUCKET=

# Optional: AWS credentials only needed if your bucket is not public-read
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-west-2
